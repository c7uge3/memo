{
  "framework": "react",
  "builds": [
    {
      "src": "./backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "./package.json",
      "use": "@vercel/static-build",
      "config": {
        "buildCommand": "npm run build && npm run server"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "./backend/server.js"
    }
  ]
}
