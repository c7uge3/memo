{
  "builds": [
    {
      "src": "./backend/server.js",
      "use": "@vercel/node",
      "config": {
        "buildCommand": "node ./backend/server.js"
      }
    },
    {
      "src": "./package.json",
      "use": "@vercel/static-build",
      "config": {
        "buildCommand": "npm run build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "./backend/server.js"
    }
  ]
}
